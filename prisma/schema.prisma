generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleKey {
  admissions_admin
  admissions_analyst
}

enum EventType {
  page_opened
  direction_opened
  compare_started
  comparison_run
  recommendation_generated
}

enum PromotionStatus {
  draft
  active
  inactive
}

model Direction {
  id                    String                  @id @default(cuid())
  code                  String?                 @unique
  slug                  String                  @unique
  title                 String
  shortDescription      String
  qualification         String?
  department            String?
  studyDuration         String?
  budgetSeats           Int?
  paidSeats             Int?
  tuitionPerYearRub     Int?
  programFocus          String?
  whatYouLearn          String?
  programDescriptionUrl String?
  curriculumUrl         String?
  learningContent       Json?
  careerPaths           String[]
  targetFit             String?
  keyDifferences        String[]
  programmingScore      Int?
  mathScore             Int?
  engineeringScore      Int?
  analyticsScore        Int?
  aiScore               Int?
  learningDifficulty    Int?
  passingScores         DirectionPassingScore[]
  promotions            DirectionPromotion[]
  subjects              DirectionSubject[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
}

model DirectionPromotion {
  id          String          @id @default(cuid())
  directionId String          @unique
  status      PromotionStatus @default(draft)
  priority    Int             @default(100)
  note        String
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  direction   Direction       @relation(fields: [directionId], references: [id], onDelete: Cascade)

  @@index([status, priority])
  @@index([startsAt, endsAt])
}

model DirectionPassingScore {
  id          String    @id @default(cuid())
  directionId String
  year        Int
  budget      Decimal?  @db.Decimal(4, 2)
  paid        Decimal?  @db.Decimal(4, 2)
  direction   Direction @relation(fields: [directionId], references: [id], onDelete: Cascade)

  @@unique([directionId, year])
  @@index([directionId])
}

model DirectionSubject {
  id           String    @id @default(cuid())
  directionId  String
  title        String
  subjectBlock String?
  department   String?
  hours        Int
  referenceUrl String?
  sortOrder    Int?
  direction    Direction @relation(fields: [directionId], references: [id], onDelete: Cascade)

  @@index([directionId])
}

model User {
  id        String   @id
  email     String?  @unique
  name      String?
  role      RoleKey
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

model Event {
  id          String    @id @default(cuid())
  type        EventType
  userId      String?
  directionId String?
  payload     Json
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}
