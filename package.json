{
  "name": "nps-choice-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.mjs",
    "test:e2e": "playwright test",
    "test:e2e:prisma": "playwright test --config playwright.prisma.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "prisma migrate reset --force",
    "check:fast": "corepack pnpm format:check && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test",
    "check": "corepack pnpm format:check && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm test:integration",
    "check:develop": "corepack pnpm check && corepack pnpm test:e2e",
    "gate:info": "node tools/quality-gates.mjs develop"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@eslint/js": "^9.22.0",
    "@eslint/eslintrc": "^3.3.1",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.0",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.27.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
